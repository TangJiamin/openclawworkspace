{
  "collection": {
    "default_count": 10,
    "max_count": 50,
    "timeout": 120
  },
  "scoring": {
    "time_weight": 0.30,
    "hot_weight": 0.30,
    "value_weight": 0.25,
    "ai_weight": 0.15,
    "threshold": 7.0
  },
  "quality": {
    "min_freshness": 0.90,
    "min_relevance": 0.95,
    "min_score": 7.5,
    "min_coverage": 3
  },
  "sources": {
    "metaso": {
      "enabled": true,
      "priority": 1,
      "name": "Metaso AI 搜索"
    },
    "ai_daily_digest": {
      "enabled": true,
      "priority": 2,
      "name": "AI Daily Digest (90个技术博客)"
    },
    "agent_reach": {
      "enabled": true,
      "priority": 3,
      "name": "Agent Reach (多平台数据源)",
      "channels": {
        "youtube": {
          "enabled": true,
          "description": "YouTube 视频信息"
        },
        "reddit": {
          "enabled": true,
          "description": "Reddit 帖子和评论"
        },
        "bilibili": {
          "enabled": true,
          "description": "B站视频和字幕"
        },
        "rss": {
          "enabled": true,
          "description": "RSS/Atom 订阅源"
        },
        "web": {
          "enabled": true,
          "description": "任意网页（Jina Reader）"
        }
      }
    }
  },
  "agent_reach": {
    "venv": "/tmp/agent-reach-venv",
    "uv_path": "~/.local/bin/uv"
  }
}
