# OpenClaw Git 忽略文件

# 临时文件
*.tmp
*.temp
*.log
*.pid

# 测试文件
/tmp/
test-*

# Agent 运行时文件
**/sessions/
**/.backup/
**/{agent,workspace}/

# 浏览器数据
**/browser/user-data/
**/*.log

# Node modules
node_modules/

# 备份文件
*.bak
*~

# 系统文件
.DS_Store
Thumbs.db

# 敏感配置（包含密钥）
*.env
.env.*
auth-profiles.json

# 但保留示例文件
!.env.example
!auth-profiles.json.example

# 编译输出
dist/
build/
